;
; SurfaceOemPanel.inf
;

[Version]
Signature="$Windows NT$"
Provider=%ManufacturerName%
ClassGuid={4d36e96e-e325-11ce-bfc1-08002be10318}
Class=Monitor
DriverVer = 07/15/2021,6.81.139.0
CatalogFile=SurfaceOemPanel.cat
PnpLockdown=1

[Manufacturer]
%ManufacturerName%=SurfaceOemPanel,NTamd64

[SurfaceOemPanel.NTamd64]
%DeviceName%=SurfaceOemPanel_Install_LGD0554, Monitor\LGD0554
%DeviceName%=SurfaceOemPanel_Install_LGD0555, Monitor\LGD0555
%DeviceName%=SurfaceOemPanel_Install_SHP14B3, Monitor\SHP14B3
%DeviceName%=SurfaceOemPanel_Install_SHP14B4, Monitor\SHP14B4
%DeviceName%=SurfaceOemPanel_Install_JDI0000, Monitor\JDI0000
%DeviceName%=SurfaceOemPanel_Install_MEI96A2, Monitor\MEI96A2
%DeviceName%=SurfaceOemPanel_Install_SHP1509, Monitor\SHP1509
%DeviceName%=SurfaceOemPanel_Install_LGD06B1, Monitor\LGD06B1
%DeviceName%=SurfaceOemPanel_Install_LGD06B2, Monitor\LGD06B2

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
SurfaceOemPanel.dll=1
ColorCalibrationComputation.dll=1
SurfacesRGB.icm=1
SurfaceEnhanced.icm=1

[DestinationDirs]
;23 == Windows\system32\spool\drivers\color
; For any new panels supporting color profiles, entry should be added here
ProfilesCopy_LGD0554=23
ProfilesCopy_LGD0555=23
ProfilesCopy_SHP14B3=23
ProfilesCopy_SHP14B4=23
;12 == Windows\System32\Drivers\UMDF
DefaultDestDir = 13

; =================== Monitor\LGD0554 ==============================
[SurfaceOemPanel_Install_LGD0554.NT]
CopyFiles=SurfaceOemPanelDriverCopy,ColorComputeDllCopy,ProfilesCopy_LGD0554
AddReg=SurfaceOemPanel_Filter_Reg, SurfaceOemPanel_RegLGD0554

[SurfaceOemPanel_RegLGD0554]
HKR,,PreferredScaleFactor,0x00010001,200
; Last entry is automatically set as default
HKR,,ICMProfile,0x00010000,"SurfacesRGB.icm"
HKR,,ICMProfile,0x00010008,"SurfaceEnhanced.icm"

[SurfaceOemPanel_Install_LGD0554.NT.hw]
AddReg=SurfaceOemPanel_Filter_Reg

[SurfaceOemPanel_Install_LGD0554.NT.Services]
AddService=WUDFRd,0x000001f8,WUDFRD_ServiceInstall
AddService=monitor,0x000001fa, Monitor_Service.Install

[SurfaceOemPanel_Install_LGD0554.NT.Wdf]
UmdfService=SurfaceOemPanel,SurfaceOemPanel_Install_LGD0554
UmdfServiceOrder=SurfaceOemPanel
UmdfKernelModeClientPolicy=AllowKernelModeClients
UmdfFsContextUsePolicy = CanUseFsContext2
UmdfFileObjectPolicy=AllowNullAndUnknownFileObjects
UmdfHostProcessSharing=ProcessSharingDisabled

[SurfaceOemPanel_Install_LGD0554]
UmdfLibraryVersion=2.15.0
ServiceBinary=%13%\SurfaceOemPanel.dll

[SurfaceOemPanel_Install_LGD0554.NT.CoInstallers]
CopyFiles=ProfilesCopy_LGD0554

; Profiles Associated with the monitor
[ProfilesCopy_LGD0554]
SurfacesRGB.icm
SurfaceEnhanced.icm

[SurfaceOemPanel_Install_LGD0554.NT.Events]
AddEventProvider = {3D53356D-424B-496A-A094-2154D8D2B304},SurfaceOemPanel_EventProviderInstall

