#define SPI_HID_MAX_RESET_ATTEMPTS 3

static struct hid_ll_driver spi_hid_ll_driver;
static int spi_hid_create_device(struct spi_hid *shid);
static int spi_hid_bus_input_report(struct spi_hid *shid);

static void spi_hid_parse_dev_desc(struct spi_hid_device_desc_raw *raw,
		struct spi_hid_device_descriptor *desc)
{
	desc->hid_version = le16_to_cpu(raw->bcdVersion);
	desc->report_descriptor_length = le16_to_cpu(raw->wReportDescLength);
	desc->report_descriptor_register =
		le16_to_cpu(raw->wReportDescRegister);
	desc->input_register = le16_to_cpu(raw->wInputRegister);
	desc->max_input_length = le16_to_cpu(raw->wMaxInputLength);
	desc->output_register = le16_to_cpu(raw->wOutputRegister);
	desc->max_output_length = le16_to_cpu(raw->wMaxOutputLength);
	desc->command_register = le16_to_cpu(raw->wCommandRegister);
	desc->vendor_id = le16_to_cpu(raw->wVendorID);
	desc->product_id = le16_to_cpu(raw->wProductID);
	desc->version_id = le16_to_cpu(raw->wVersionID);
	desc->device_power_support = 0;
	desc->power_response_delay = 0;
}

static void spi_hid_populate_input_header(__u8 *buf,
		struct spi_hid_input_header *header)
{
	header->version       = (buf[0] >> 0) & 0xf;
	header->report_type   = (buf[0] >> 4) & 0xf;
	header->fragment_id   = (buf[1] >> 0) & 0xf;
	header->report_length = ((((buf[1] >> 4) & 0xf) << 0) |
			(buf[2] << 4)) * 4;
	header->sync_const    = buf[3];
}

static void spi_hid_populate_input_body(__u8 *buf,
		struct spi_hid_input_body *body)
{
	u16 raw_len = buf[0] | (buf[1] << 8);

	body->content_length = raw_len >= (sizeof(body->content_length) + sizeof(body->content_id))
		? raw_len - (sizeof(body->content_length) + sizeof(body->content_id))
		: 0;
	body->content_id = buf[2];
}

static void spi_hid_input_report_prepare(struct spi_hid_input_buf *buf,
		struct spi_hid_input_report *report)
{
	struct spi_hid_input_header header;
	struct spi_hid_input_body body;

	spi_hid_populate_input_header(buf->header, &header);
	spi_hid_populate_input_body(buf->body, &body);
	report->report_type = header.report_type;
	report->content_length = body.content_length;
	report->content_id = body.content_id;
	report->content = buf->content;
}

static void spi_hid_output_header(__u8 *buf,
		u16 output_register, u16 output_report_length)
{
	buf[0] = SPI_HID_OUTPUT_HEADER_OPCODE_WRITE;
	buf[1] = (output_register >> 16) & 0xff;
	buf[2] = (output_register >> 8) & 0xff;
	buf[3] = (output_register >> 0) & 0xff;
	buf[4] = (SPI_HID_OUTPUT_HEADER_VERSION << 0) |
			(((output_report_length >> 0) & 0xf) << 4);
	buf[5] = (output_report_length >> 4) & 0xff;
}

static void spi_hid_output_body(__u8 *buf,
		struct spi_hid_output_report *report)
{
	u16 content_length = report->content_length;

	buf[0] = report->content_type;
	buf[1] = (content_length >> 0) & 0xff;
	buf[2] = (content_length >> 8) & 0xff;
	buf[3] = report->content_id;
}

/*
 * Windows' ta264 SPI capture (linux-surface#51) shows byte[7] of this
 * 9-byte approval frame as 0x00 for the very first read (RESET_RESP,
 * before any descriptor request), but 0x03 for every subsequent read
 * once the device has ack'd a descriptor request (DEVICE_DESC header,
 * body, REPORT_DESC header, body all show byte[7]=0x03). Our regular
 * reads always hardcoded byte[7]=0x00, which may be why the device
 * keeps responding with RESET_RESP even after a successfully-acked
 * descriptor request - it may be reading this byte as a protocol-stage
 * flag and seeing us stuck in "stage 0" forever.
 */
static bool spi_hid_desc_request_acked;

static void spi_hid_read_approval(u32 input_register, u8 *buf)
{
	buf[0] = SPI_HID_READ_APPROVAL_OPCODE_READ;
	buf[1] = (input_register >> 16) & 0xff;
	buf[2] = (input_register >> 8) & 0xff;
	buf[3] = (input_register >> 0) & 0xff;
	buf[4] = SPI_HID_READ_APPROVAL_CONSTANT;
	buf[5] = 0x00;
	buf[6] = 0x00;
	buf[7] = spi_hid_desc_request_acked ? 0x03 : 0x00;
	buf[8] = 0x00;
}

static int spi_hid_input_async(struct spi_hid *shid, void *buf, u16 length,
		void (*complete)(void*))
{
	int ret;

	shid->input_transfer[0].tx_buf = shid->read_approval;
	shid->input_transfer[0].len = SPI_HID_READ_APPROVAL_LEN;

	shid->input_transfer[1].rx_buf = buf;
	shid->input_transfer[1].len = length;

	/*
	 * Optimization opportunity: we really do not need the input_register
	 * field in struct spi_hid; we can calculate the read_approval field
	 * with default input_register value during probe and then re-calculate
	 * from spi_hid_parse_dev_desc. And then we can get rid of the below
	 * spi_hid_read_approval call which is run twice per interrupt.
	 *
	 * Long term, for spec v1.0, we'll be using the input_register value
	 * from device tree, not from the device descriptor.
	 */
	spi_hid_read_approval(shid->desc.input_register,
			shid->read_approval);
	spi_message_init_with_transfers(&shid->input_message,
			shid->input_transfer, 2);

	shid->input_message.complete = complete;
	shid->input_message.context = shid;

	trace_spi_hid_input_async(shid,
			shid->input_transfer[0].tx_buf,
			shid->input_transfer[0].len,
			shid->input_transfer[1].rx_buf,
			shid->input_transfer[1].len, 0);

	ret = spi_async(shid->spi, &shid->input_message);
	if (ret) {
		shid->bus_error_count++;
		shid->bus_last_error = ret;
	}

	return ret;
}

static int spi_hid_output(struct spi_hid *shid, void *buf, u16 length)
{
	struct spi_transfer transfer;
	struct spi_message message;
	int ret;

	memset(&transfer, 0, sizeof(transfer));

	transfer.tx_buf = buf;
	transfer.len = length;

	spi_message_init_with_transfers(&message, &transfer, 1);

	/*
	 * REVISIT: Should output be asynchronous?
	 *
	 * According to Documentation/hid/hid-transport.rst, ->output_report()
	 * must be implemented as an asynchronous operation.
	 */
	trace_spi_hid_output_begin(shid, transfer.tx_buf,
			transfer.len, NULL, 0, 0);

	ret = spi_sync(shid->spi, &message);

	trace_spi_hid_output_end(shid, transfer.tx_buf,
			transfer.len, NULL, 0, ret);

	if (ret) {
		shid->bus_error_count++;
		shid->bus_last_error = ret;
	}

	return ret;
}

static const char *const spi_hid_power_mode_string(u8 power_state)
{
	switch (power_state) {
	case SPI_HID_POWER_MODE_ACTIVE:
		return "d0";
	case SPI_HID_POWER_MODE_SLEEP:
		return "d2";
	case SPI_HID_POWER_MODE_OFF:
		return "d3";
	case SPI_HID_POWER_MODE_WAKING_SLEEP:
		return "d3*";
	default:
		return "unknown";
	}
}

static int spi_hid_power_down(struct spi_hid *shid)
{
	struct device *dev = &shid->spi->dev;
	int ret;

	if (!shid->powered)
		return 0;

	if (shid->spi->dev.of_node) {
		pinctrl_select_state(shid->pinctrl, shid->pinctrl_sleep);

		ret = regulator_disable(shid->supply);
		if (ret) {
			dev_err(dev, "failed to disable regulator\n");
			return ret;
		}
	}

	shid->powered = false;

	return 0;
}

static struct hid_device *spi_hid_disconnect_hid(struct spi_hid *shid)
{
	struct hid_device *hid = shid->hid;

	shid->hid = NULL;

	return hid;
}

static void spi_hid_stop_hid(struct spi_hid *shid)
{
	struct hid_device *hid;

	hid = spi_hid_disconnect_hid(shid);
	if (hid) {
		cancel_work_sync(&shid->create_device_work);
		cancel_work_sync(&shid->refresh_device_work);
		hid_destroy_device(hid);
	}
}

static int spi_hid_reset_via_acpi(struct spi_hid *shid)
{
	acpi_handle handle = ACPI_HANDLE(&shid->spi->dev);
	acpi_status status;

	status = acpi_evaluate_object(handle, "_RST", NULL, NULL);
	if (ACPI_FAILURE(status))
		return -EFAULT;

	return 0;
}

static int spi_hid_error_handler(struct spi_hid *shid)
{
	struct device *dev = &shid->spi->dev;
	int ret = 0;

	mutex_lock(&shid->power_lock);
	if (shid->power_state == SPI_HID_POWER_MODE_OFF)
		goto out;

	dev_err(dev, "Error Handler\n");

	if (shid->attempts++ >= SPI_HID_MAX_RESET_ATTEMPTS) {
		dev_err(dev, "unresponsive device, aborting.\n");
		spi_hid_stop_hid(shid);
		spi_hid_power_down(shid);

		ret = -ESHUTDOWN;
		goto out;
	}

	shid->ready = false;
	sysfs_notify(&dev->kobj, NULL, "ready");

	if (dev->of_node) {
		ret = pinctrl_select_state(shid->pinctrl, shid->pinctrl_reset);
		if (ret) {
			dev_err(dev, "Power Reset failed\n");
			goto out;
		}
	}

	shid->power_state = SPI_HID_POWER_MODE_OFF;
	shid->input_stage = SPI_HID_INPUT_STAGE_IDLE;
	shid->input_transfer_pending = 0;
	cancel_work_sync(&shid->reset_work);

	if (dev->of_node) {
		/* Drive reset for at least 100 ms */
		msleep(100);
	}

	shid->power_state = SPI_HID_POWER_MODE_ACTIVE;

	if (dev->of_node) {
		ret = pinctrl_select_state(shid->pinctrl, shid->pinctrl_active);
		if (ret) {
			dev_err(dev, "Power Restart failed\n");
			goto out;
		}
	} else {
		ret = spi_hid_reset_via_acpi(shid);
		if (ret) {
			dev_err(dev, "Reset failed\n");
			goto out;
		}
	}

out:
	mutex_unlock(&shid->power_lock);
	return ret;
}

static void spi_hid_error_work(struct work_struct *work)
{
	struct spi_hid *shid = container_of(work, struct spi_hid, error_work);
	struct device *dev = &shid->spi->dev;
	int ret;

	ret = spi_hid_error_handler(shid);
	if (ret)
		dev_err(dev, "%s: error handler failed\n", __func__);
}

/* AMD FCH SPI controller undocumented CTRL0 bits from amdspi.sys decompilation:
 * bit 18 (0x00040000), bit 29 (0x20000000), bit 30 (0x40000000).
 * Windows sets these alongside FIFO_CLEAR before each V2 transfer.
 */
#define AMD_FCH_CTRL0_SECRET		(BIT(29) | BIT(30) | BIT(18))
#define AMD_FCH_SPI_MMIO_BASE		0xFEC10000
#define AMD_FCH_SPI_MMIO_SIZE		0x100
#define AMD_FCH_SPI_CTRL0_REG		0x00
#define AMD_FCH_SPI_OPCODE_MASK	0xFF
#define AMD_FCH_SPI_FIFO_CLEAR		BIT(20)
#define AMD_FCH_SPI_EXEC_CMD		BIT(16)
#define AMD_FCH_SPI_BUSY		BIT(31)
#define AMD_FCH_SPI_OPCODE_REG		0x45
#define AMD_FCH_SPI_CMD_TRIGGER_REG	0x47
#define AMD_FCH_SPI_TRIGGER_CMD	BIT(7)
#define AMD_FCH_SPI_TX_COUNT_REG	0x4B	/* from amdspi.sys decomp: chunk+1 */
#define AMD_FCH_SPI_RX_COUNT_REG	0x4D	/* speculative, not confirmed */
#define AMD_FCH_SPI_STATUS_REG		0x04	/* Real AMD SPI status, 32-bit, bit31=SPIIdle */
#define AMD_FCH_SPI_STATUS_BYTE		0x4C	/* Windows byte status (different reg) */
#define AMD_FCH_SPI_FIFO_BASE		0x80
#define AMD_FCH_SPI_REG48		0x48	/* written 3 before xfer (decomp) */
#define AMD_FCH_SPI_CTRL0_SECRET	0x60040000  /* bits 30+29+18 */
#define AMD_FCH_SPI_FIFO_DATA_OFFSET	4	/* FIFO_BASE + 4 for RX data */

static void __iomem *spi_hid_fch_spi_base;

static void spi_hid_fch_clear_fifo_ptr(void __iomem *base)
{
	u32 ctrl0 = ioread32(base + AMD_FCH_SPI_CTRL0_REG);
	ctrl0 &= ~AMD_FCH_SPI_FIFO_CLEAR;
	iowrite32(ctrl0, base + AMD_FCH_SPI_CTRL0_REG);
	ctrl0 |= AMD_FCH_SPI_FIFO_CLEAR;
	iowrite32(ctrl0, base + AMD_FCH_SPI_CTRL0_REG);
}

/*
 * V2 combined transfer with Windows-decompiled undocumented CTRL0 bits.
 * Updated with amdspi.sys decomp findings: 0x1D init, 0x48=3, 0x4B=TX_COUNT, FIFO+4 RX.
 */
static int spi_hid_v2_combined_xfer(void __iomem *base, const u8 *tx, u8 tx_len,
				    u8 *rx, u8 rx_len, u8 opcode, bool use_secret)
{
	u32 ctrl0;
	int i, timeout;

	/* DEBUG: read STATUS at 0x04 and 0x4C to compare */
	{
		u32 s04 = ioread32(base + 0x04);
		u8 s4c = ioread8(base + 0x4C);
		pr_info("spi_amd: STATUS04=0x%08x STATUS4C=0x%02x\n", s04, s4c);
	}
	/* Wait for controller idle before starting */
	timeout = 100000;
	while ((ioread32(base + 0x04) & BIT(31)) && --timeout)
		udelay(1);
	if (!timeout)
		return -ETIMEDOUT;

	/* Windows init: register 0x1D = (read & 0xFC) | 1 (amdspi.sys decomp) */
	{
		u8 r1d = ioread8(base + 0x1D);
		r1d = (r1d & 0xFC) | 1;
		iowrite8(r1d, base + 0x1D);
	}

	spi_hid_fch_clear_fifo_ptr(base);

	for (i = 0; i < tx_len; i++)
		iowrite8(tx[i], base + AMD_FCH_SPI_FIFO_BASE + i);

	/* Windows writes 2 zero bytes after TX (amdspi.sys decomp, optimal from sweep) */
	iowrite8(0, base + AMD_FCH_SPI_FIFO_BASE + tx_len + 0);
	iowrite8(0, base + AMD_FCH_SPI_FIFO_BASE + tx_len + 1);

	ctrl0 = ioread32(base + AMD_FCH_SPI_CTRL0_REG);
	ctrl0 |= AMD_FCH_SPI_FIFO_CLEAR;
	iowrite32(ctrl0, base + AMD_FCH_SPI_CTRL0_REG);

	if (use_secret) {
		ctrl0 = ioread32(base + AMD_FCH_SPI_CTRL0_REG);
		ctrl0 |= AMD_FCH_SPI_CTRL0_SECRET;
		iowrite32(ctrl0, base + AMD_FCH_SPI_CTRL0_REG);

		{
			u16 reg44 = ioread16(base + 0x44);
			reg44 &= 0xf0ff; reg44 |= (u16)(1 & 0xf) << 8;
			reg44 &= 0x0fff; reg44 |= (u16)(1 & 0xf) << 12;
			iowrite16(reg44, base + 0x44);
		}
	}

	/* TX_COUNT includes the 2 zero bytes */
	iowrite8(tx_len + 2, base + AMD_FCH_SPI_TX_COUNT_REG);
	iowrite8(rx_len, base + AMD_FCH_SPI_RX_COUNT_REG);

	iowrite8(opcode, base + AMD_FCH_SPI_OPCODE_REG);

	/* Windows: register 0x48 = 3 (amdspi.sys decomp, before CMD_TRIGGER) */
	iowrite8(3, base + AMD_FCH_SPI_REG48);

	/* Strobe undocumented registers AFTER OPCODE_REG (Windows order) */
	iowrite8(0x00, base + 0x49);
	iowrite8(0x00, base + 0x4a);

	{
		u8 trig = ioread8(base + AMD_FCH_SPI_CMD_TRIGGER_REG);
		trig &= ~AMD_FCH_SPI_TRIGGER_CMD;
		iowrite8(trig, base + AMD_FCH_SPI_CMD_TRIGGER_REG);
		trig |= AMD_FCH_SPI_TRIGGER_CMD;
		iowrite8(trig, base + AMD_FCH_SPI_CMD_TRIGGER_REG);
	}

	/* Wait for transfer to START (BUSY=1) then COMPLETE (BUSY=0) */
	{
		u32 s;
		/* Wait for bus to become busy (transfer started) */
		timeout = 100000;
		while (!((s = ioread32(base + 0x04)) & BIT(31)) && --timeout)
			udelay(1);
		pr_info("spi_amd: BUSY_START status=0x%08x timeout=%d\n", s, timeout > 0);
		if (!timeout) {
			/* Never became busy — use fixed delay */
			udelay(500);
		} else {
			/* Wait for transfer to complete */
			while ((ioread32(base + 0x04) & BIT(31)) && --timeout)
				udelay(1);
			pr_info("spi_amd: BUSY_END timeout=%d\n", timeout > 0);
		}
	}

	/* Windows reads RX from FIFO + 4 (offset 0x84) */
	for (i = 0; i < rx_len; i++)
		rx[i] = ioread8(base + AMD_FCH_SPI_FIFO_BASE + AMD_FCH_SPI_FIFO_DATA_OFFSET + i);

	return 0;
}

static void spi_hid_sweep_fch_regs(struct spi_hid *shid, void __iomem *base)
{
	u8 payload[9] = { 0x00, 0x00, 0x01, 0x42, 0x00, 0x00, 0x03, 0x00, 0x00 };
	u8 baseline[10] = { 0 }, rx[10] = { 0 };
	int offset, val_i;

	spi_hid_v2_combined_xfer(base, payload, 9, baseline, 10, 0x02, true);

	for (offset = 0x40; offset <= 0x50; offset++) {
		if (offset == 0x44 || offset == 0x45 || offset == 0x47 ||
		    offset == 0x48 || offset == 0x4B || offset == 0x4C)
			continue;

		for (val_i = 0; val_i < 2; val_i++) {
			u8 val = val_i ? 0xFF : 0x00;
			u8 saved = ioread8(base + offset);

			iowrite8(val, base + offset);
			spi_hid_v2_combined_xfer(base, payload, 9, rx, 10, 0x02, true);
			iowrite8(saved, base + offset);

			if (memcmp(rx, baseline, 10) != 0) {
				dev_info(&shid->spi->dev,
					 "FCH reg 0x%02x=0x%02x CHANGED rx: [%02x %02x %02x %02x %02x %02x %02x %02x %02x %02x]\n",
					 offset, val,
					 rx[0], rx[1], rx[2], rx[3], rx[4],
					 rx[5], rx[6], rx[7], rx[8], rx[9]);
			}
		}
	}
	dev_info(&shid->spi->dev, "FCH reg sweep (0x40-0x50) complete\n");
}

static void spi_hid_sweep_ctrl0_bits(struct spi_hid *shid, void __iomem *base)
{
	u8 payload[9] = { 0x00, 0x00, 0x01, 0x42, 0x00, 0x00, 0x03, 0x00, 0x00 };
	u8 baseline[10] = { 0 }, rx[10] = { 0 };
	u32 saved = ioread32(base + AMD_FCH_SPI_CTRL0_REG);
	int bit;

	spi_hid_v2_combined_xfer(base, payload, 9, baseline, 10, 0x02, true);

	for (bit = 0; bit < 32; bit++) {
		u32 ctrl0 = saved;
		ctrl0 &= ~(BIT(16) | BIT(20) | BIT(29) | BIT(30) | BIT(18));
		ctrl0 |= BIT(bit);
		iowrite32(ctrl0, base + AMD_FCH_SPI_CTRL0_REG);

		spi_hid_v2_combined_xfer(base, payload, 9, rx, 10, 0x02, true);

		if (memcmp(rx, baseline, 10) != 0) {
			dev_info(&shid->spi->dev,
				 "CTRL0 bit %d changed rx: [%02x %02x %02x %02x %02x %02x %02x %02x %02x %02x]\n",
				 bit,
				 rx[0], rx[1], rx[2], rx[3], rx[4],
				 rx[5], rx[6], rx[7], rx[8], rx[9]);
		}
	}

	/* Also try pairs: bits that together might enable something */
	for (bit = 0; bit < 31; bit++) {
		u32 ctrl0 = saved;
		ctrl0 &= ~(BIT(16) | BIT(20) | BIT(29) | BIT(30) | BIT(18));
		ctrl0 |= BIT(bit) | BIT(bit+1);
		iowrite32(ctrl0, base + AMD_FCH_SPI_CTRL0_REG);

		spi_hid_v2_combined_xfer(base, payload, 9, rx, 10, 0x02, true);

		if (memcmp(rx, baseline, 10) != 0 &&
		    memcmp(rx, rx, 10) == 0 /* always true, just need unique log per pair */) {
			/* Only log if different from single-bit results */
		}
	}

	iowrite32(saved, base + AMD_FCH_SPI_CTRL0_REG);
	dev_info(&shid->spi->dev, "CTRL0 bit sweep complete\n");
}

static int spi_hid_send_output_report(struct spi_hid *shid, u32 output_register,
		struct spi_hid_output_report *report);
static int spi_hid_sync_request(struct spi_hid *shid, u16 output_register,
		struct spi_hid_output_report *report);

static void spi_hid_reset_work(struct work_struct *work)
{
	struct spi_hid *shid =
		container_of(work, struct spi_hid, reset_work);
	struct device *dev = &shid->spi->dev;
	int ret;

	trace_spi_hid_reset_work(shid);

	dev_err(dev, "Reset Handler (attempt=%u)\n", shid->attempts);

	if (shid->ready) {
		dev_err(dev, "Spontaneous FW reset!");
		shid->ready = false;
		shid->dir_count++;
		sysfs_notify(&dev->kobj, NULL, "ready");
	}

	if (flush_work(&shid->create_device_work))
		dev_err(dev, "Reset handler waited for create_device_work");

	if (shid->power_state == SPI_HID_POWER_MODE_OFF) {
		return;
	}

	if (flush_work(&shid->refresh_device_work))
		dev_err(dev, "Reset handler waited for refresh_device_work");
	if (shid->attempts == 0) {

	/* Hardcode descriptor and create HID device */
	memset(&shid->desc, 0, sizeof(shid->desc));
	shid->desc.hid_version = 0x0100;
	shid->desc.report_descriptor_length = 0;
	shid->desc.report_descriptor_register = 0x0002;
	shid->desc.input_register = 0x0000; /* confirmed: device uses register 0 */
	shid->desc.max_input_length = 120;
	shid->desc.output_register = 0x0001;
	shid->desc.max_output_length = 120;
	shid->desc.command_register = 0x0000;

	shid->waiting_for_descriptor = false;
	shid->ready = true;
	shid->keep_powered = true;
	}

	if (!shid->hid) {
		ret = spi_hid_create_device(shid);
		if (ret)
			dev_err(dev, "Failed to create HID device: %d\n", ret);
		else
			dev_info(dev, "HID device created, ready=true\n");
	}

	return;
}

static int spi_hid_input_report_handler(struct spi_hid *shid,
		struct spi_hid_input_buf *buf)
{
	struct device *dev = &shid->spi->dev;
	struct spi_hid_input_report r;
	int ret;

	dev_err(dev, "Input Report Handler\n");

	trace_spi_hid_input_report_handler(shid);

	if (!shid->ready) {
		dev_err(dev, "discarding input report, not ready!\n");
		return 0;
	}

	if (shid->refresh_in_progress) {
		dev_err(dev, "discarding input report, refresh in progress!\n");
		return 0;
	}

	if (!shid->hid) {
		dev_err(dev, "discarding input report, no HID device!\n");
		return 0;
	}

	spi_hid_input_report_prepare(buf, &r);

	if (shid->perf_mode &&
			(r.content_id == SPI_HID_RIGHT_SCREEN_TOUCH_HEAT_MAP_REPORT_ID ||
			r.content_id == SPI_HID_LEFT_SCREEN_TOUCH_HEAT_MAP_REPORT_ID)) {
		r.content[1] = shid->touch_signature_index >> 8;
		r.content[0] = shid->touch_signature_index++;
	}

	ret = hid_input_report(shid->hid, HID_INPUT_REPORT,
			r.content - 1,
			r.content_length + 1, 1);

	if (shid->perf_mode &&
			(r.content_id == SPI_HID_HEARTBEAT_REPORT_ID ||
			r.content_id == SPI_HID_RIGHT_SCREEN_TOUCH_HEAT_MAP_REPORT_ID ||
			r.content_id == SPI_HID_LEFT_SCREEN_TOUCH_HEAT_MAP_REPORT_ID)) {
		shid->latencies[shid->latency_index].end_time = ktime_get_ns();
		shid->latencies[shid->latency_index].report_id = r.content_id;
		shid->latencies[shid->latency_index].signature = (r.content[1] << 8) | r.content[0];
		shid->latencies[shid->latency_index].start_time = shid->interrupt_time_stamps[0];

		shid->latency_index = (shid->latency_index + 1) % SPI_HID_MAX_LATENCIES;
	}

	if (ret == -ENODEV || ret == -EBUSY) {
		dev_err(dev, "ignoring report --> %d\n", ret);
		return 0;
	}

	return ret;
}

static int spi_hid_response_handler(struct spi_hid *shid,
		struct spi_hid_input_buf *buf)
{
	trace_spi_hid_response_handler(shid);
	dev_err(&shid->spi->dev, "Response Handler\n");

	/* completion_done returns 0 if there are waiters, otherwise 1 */
	if (completion_done(&shid->output_done))
		dev_err(&shid->spi->dev, "Unexpected response report\n");
	else
		complete(&shid->output_done);

	return 0;
}

static int spi_hid_send_output_report(struct spi_hid *shid, u32 output_register,
		struct spi_hid_output_report *report)
{
	struct spi_hid_output_buf *buf = &shid->output;
	struct device *dev = &shid->spi->dev;

	u16 padded_length;
	u16 body_length;
	u8 padding;
	u16 max_length;

	int ret;

	body_length = sizeof(buf->body) + report->content_length;
	padded_length = round_up(body_length, 4);
	padding = padded_length - body_length;
	max_length = round_up(shid->desc.max_output_length + 3
						+ sizeof(buf->body), 4);

	if (padded_length < report->content_length) {
		dev_err(dev, "Output report padded_length overflow\n");
		ret = -E2BIG;
		goto out;
	}

	if (padded_length > max_length) {
		dev_err(dev, "Output report too big\n");
		ret = -E2BIG;
		goto out;
	}

	spi_hid_output_header(buf->header, output_register, padded_length);
	spi_hid_output_body(buf->body, report);

	if (report->content_length > 3)
		memcpy(&buf->content, report->content, report->content_length);

	memset(&buf->content[report->content_length], 0, padding);

	ret = spi_hid_output(shid, buf, sizeof(buf->header) +
			padded_length);
	if (ret) {
		dev_err(dev, "failed output transfer\n");
		goto out;
	}

	return 0;

out:
	return ret;
}

/*
 * Send an explicit SET_POWER command over the SPI-HID wire, right after
 * ACPI _RST and *before* ever requesting the device descriptor. Without it,
 * this device's SPI-HID controller stays logically asleep (all reads
 * return 0xFF) even though its reset/power GPIOs are already correctly
 * toggled.
 *
 * Reverse-engineered from HidSpiCx.sys (the WDF class extension that
 * hidspi.sys depends on per its own INF - "Dependencies = HidSpiCx" -
 * confirming HidSpiCx.sys is the actual driver talking to the SPI bus on
 * this Windows build, not hidspi.sys' older/legacy "V0" state machine).
 * HidSpiCx's HidSpiDevice::ConfigurePowerTransfer builds a short 5-byte
 * command with NO register address at all (unlike the older "V0" protocol
 * this driver was originally ported from):
 *   buf[0] = 7             (fixed "POWER" opcode)
 *   buf[1] = 1             (fixed)
 *   buf[2] = 0             (fixed)
 *   buf[3] = 1             (fixed)
 *   buf[4] = power_state   (1=D0/active, 2=D2/sleep, 3=D3/off)
 *
 * Verified empirically: sending byte 0x07 as the AMD FCH SPI opcode with
 * [0x01, 0x00, 0x01, power_state] as the remaining payload makes the
 * previously always-0xFF device answer the very next input-register read
 * with a genuine SPI-HID header (sync_const=0x5A, report_type=
 * SPI_HID_REPORT_TYPE_RESET_RESP), which is exactly what
 * spi_hid_input_header_complete()'s reset_work path is waiting for.
 */
static int spi_hid_send_set_power_once(struct spi_hid *shid, u8 power_state)
{
	/*
	 * Confirmed from decompiling HidSpiCx.sys
	 * HidSpiDevice::ConfigurePowerTransfer (0x14000a5d8):
	 *   buf[0] = 7 (opcode, will be stripped by amd_spi)
	 *   buf[1] = 1 (word [1,0] = LE 0x0001)
	 *   buf[2] = 0
	 *   buf[3] = 1
	 *   buf[4] = power_state (1/2/3)
	 *   buf[5..7] = 0 (memset'd, function returns len=8)
	 *
	 * Previous 5-byte version (buf[0]=7 buf[1..4]=[1,0,1,power])
	 * was missing the trailing 3 zero bytes that the real
	 * Windows driver includes.
	 */
	u8 buf[8] = { 0x07, 0x01, 0x00, 0x01, power_state, 0x00, 0x00, 0x00 };
	struct spi_transfer transfer = {
		.tx_buf = buf,
		.len = sizeof(buf),
	};
	struct spi_message message;
	int ret;

	spi_message_init_with_transfers(&message, &transfer, 1);
	ret = spi_sync(shid->spi, &message);
	if (ret) {
		shid->bus_error_count++;
		shid->bus_last_error = ret;
	}

	return ret;
}

/*
 * Older "V0"-style descriptor request write (opcode=WRITE(2), register=1,
 * header byte4=0x42 i.e. version=2/len=4, 4 zero body bytes) - the same
 * thing spi_hid_reset_work() sends further down in this file. In our one
 * successful manual test, this exact write happened (among other probing)
 * shortly before a HidSpiCx-style SET_POWER attempt finally got a valid
 * 0x5A response; sending it here tests whether it's a necessary precursor
 * rather than the repeated SET_POWER retries alone being sufficient.
 */
static int spi_hid_send_v0_descriptor_request_once(struct spi_hid *shid)
{
	u8 buf[10] = { 0x02, 0x00, 0x00, 0x01, 0x42, 0x00, 0x00, 0x00, 0x00, 0x00 };
	struct spi_transfer transfer = {
		.tx_buf = buf,
		.len = sizeof(buf),
	};
	struct spi_message message;

	spi_message_init_with_transfers(&message, &transfer, 1);
	return spi_sync(shid->spi, &message);
}

/*
 * Raw probe read: read-approval for the default input register (0x1000)
 * followed by an 8-byte read, done directly via spi_sync (bypassing the
 * async input-report machinery) so we can immediately check for a valid
 * sync byte (0x5A) right after sending SET_POWER, without waiting for the
 * IRQ-driven path to get around to it.
 */
static bool spi_hid_probe_read_valid(struct spi_hid *shid)
{
	struct device *dev = &shid->spi->dev;
	u8 rx[9] = { 0 };
	int ret;

	spi_hid_read_approval(shid->desc.input_register, shid->read_approval);

	struct spi_transfer transfers[2] = {
		{ .tx_buf = shid->read_approval, .len = SPI_HID_READ_APPROVAL_LEN },
		{ .rx_buf = rx, .len = sizeof(rx) },
	};
	struct spi_message message;

	spi_message_init_with_transfers(&message, transfers, 2);
	ret = spi_sync(shid->spi, &message);
	if (ret) {
		dev_warn(dev, "probe_read_valid: spi_sync failed %d\n", ret);
		return false;
	}

	if (rx[8] == SPI_HID_INPUT_HEADER_SYNC_BYTE) {
		dev_info(dev, "probe_read_valid: sync=0x%02x [%02x %02x %02x %02x %02x %02x %02x %02x %02x]\n",
			 rx[8], rx[0], rx[1], rx[2], rx[3], rx[4], rx[5], rx[6], rx[7], rx[8]);
		return true;
	}

	dev_dbg(dev, "probe_read_valid: no sync [%02x %02x %02x %02x %02x %02x %02x %02x %02x]\n",
		rx[0], rx[1], rx[2], rx[3], rx[4], rx[5], rx[6], rx[7], rx[8]);
	return false;
}

/*
 * A single SET_POWER send only very rarely lands at the right moment - the
 * device appears to only accept/respond within some short internal window
 * (possibly synchronized to its own interrupt cycle) rather than being
 * unconditionally woken by any one command. Retry a number of times with a
 * short send+read+delay cycle to reliably catch that window.
 */
static int spi_hid_send_set_power(struct spi_hid *shid, u8 power_state)
{
	int ret;
	int i;

	/*
	 * Retry SET_POWER multiple times with a short send+read+delay
	 * cycle. The device may only accept/respond within a short
	 * internal window synchronized to its own startup cycle.
	 */
	for (i = 0; i < 40; i++) {
		ret = spi_hid_send_set_power_once(shid, power_state);
		if (ret)
			return ret;

		if (spi_hid_probe_read_valid(shid)) {
			dev_info(&shid->spi->dev,
				 "SET_POWER(%u) got valid sync after %d attempt(s)\n",
				 power_state, i + 1);
			return 0;
		}

		usleep_range(20000, 25000);
	}

	dev_warn(&shid->spi->dev, "SET_POWER(%u): no valid sync after 40 attempts\n",
		 power_state);
	return 0;
}

/*
* This function shouldn't be called from the interrupt thread context since it
* waits for completion that gets completed in one of the future runs of the
* interrupt thread.
*/
static int spi_hid_sync_request(struct spi_hid *shid, u16 output_register,
		struct spi_hid_output_report *report)
{
	struct device *dev = &shid->spi->dev;
	int ret = 0;


	ret = spi_hid_send_output_report(shid, output_register,
			report);
	if (ret) {
		dev_err(dev, "failed to transfer output report\n");
		return ret;
	}

	mutex_unlock(&shid->lock);
	ret = wait_for_completion_interruptible_timeout(&shid->output_done,
			msecs_to_jiffies(1000));
	mutex_lock(&shid->lock);
	if (ret == 0) {
		dev_err(dev, "response timed out\n");
		schedule_work(&shid->error_work);
		return -ETIMEDOUT;
	}

	return 0;
}

